{
  "watch": [
    "server.js",
    "app.js",
    "src/**/*.js"
  ],
  "ignore": [
    "node_modules/**",
    "uploads/**",
    "logs/**",
    "test/**",
    "tests/**",
    "*.test.js",
    "*.spec.js",
    "docs/**",
    "public/**",
    ".git/**",
    "coverage/**"
  ],
  "ext": "js,json",
  "delay": 1000,
  "env": {
    "NODE_ENV": "development"
  },
  "verbose": true,
  "restartable": "rs",
  "colours": true,
  "execMap": {
    "js": "node"
  }
}
