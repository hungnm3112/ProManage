          <!-- Unified Preview -->
          <div class="bg-purple-50 p-3 rounded-lg border border-purple-200">
            <p class="text-xs font-semibold text-gray-600 mb-1">
              🔮 Deadline tiếp theo:
            </p>
            <p id="editDeadlinePreview" class="text-sm font-medium text-purple-700">
              <!-- Updated by JavaScript -->
            </p>
          </div>
        </div>
      </form>
      
      <!-- Fixed Action Buttons -->
      <div class="sticky bottom-0 bg-white border-t border-gray-200 px-4 sm:px-6 py-3 sm:py-4 flex flex-col sm:flex-row justify-center gap-3">
        <button id="cancelEditDetailsBtn" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 min-h-[48px] font-medium text-sm sm:text-base order-2 sm:order-1">
          Hủy
        </button>
        <button id="saveEditDetailsBtn" class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold min-h-[48px] text-sm sm:text-base flex items-center justify-center gap-2 order-1 sm:order-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          Lưu thay đổi
        </button>
      </div>
    </div>
  </div>

  <!-- Edit Task Reassign Modal (like Assign Modal) -->
  <div id="editTaskReassignModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-end sm:items-center justify-center p-0 sm:p-4">
    <div class="bg-white rounded-t-2xl sm:rounded-xl shadow-2xl w-full sm:max-w-5xl max-h-[95vh] sm:max-h-[90vh] flex flex-col">
      <!-- Header -->
      <div class="flex-shrink-0 sticky top-0 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center">
        <div>
          <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Giao Lại Công Việc</h3>
          <p id="reassignTaskTitle" class="text-sm text-gray-600 mt-1"></p>
        </div>
        <button id="closeEditReassignModal" class="text-gray-400 hover:text-gray-600 min-w-[44px] min-h-[44px] flex items-center justify-center">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      
      <!-- Scrollable Content -->
      <div class="flex-1 overflow-y-auto p-4 sm:p-6">
        <!-- Tabs -->
        <div class="flex gap-2 mb-6 border-b border-gray-200">
          <button id="reassignStoresTab" class="tab-btn active flex-1 px-4 py-3 font-semibold border-b-2 border-blue-600 text-blue-600 transition-colors text-center">
            <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"></path>
            </svg>
            Chi nhánh
          </button>
          <button id="reassignEmployeesTab" class="tab-btn flex-1 px-4 py-3 font-semibold border-b-2 border-transparent text-gray-600 hover:text-gray-900 transition-colors text-center">
            <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-2a6 6 0 0112 0v2zm0 0h6v-2a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            Nhân viên
          </button>
        </div>

        <!-- Store Reassignment Tab -->
        <div id="reassignStoresContent" class="tab-content">
          <div class="mb-4">
            <input type="text" id="reassignStoreSearch" placeholder="Tìm kiếm chi nhánh..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-base min-h-[48px]">
          </div>
          <div id="reassignStoresList" class="space-y-2">
            <p class="text-center text-gray-500 py-8">Đang tải...</p>
          </div>
        </div>

        <!-- Employee Reassignment Tab -->
        <div id="reassignEmployeesContent" class="tab-content hidden">
          <div class="mb-4">
            <input type="text" id="reassignEmployeeSearch" placeholder="Tìm kiếm nhân viên theo tên..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-base min-h-[48px]">
          </div>
          <div id="reassignEmployeesList" class="space-y-2">
            <p class="text-center text-gray-500 py-8">Đang tải...</p>
          </div>
        </div>
      </div>

      <!-- Fixed Action Buttons -->
      <div class="flex-shrink-0 sticky bottom-0 bg-white border-t border-gray-200 px-4 sm:px-6 py-3 sm:py-4 flex flex-row justify-center gap-3">
        <button id="cancelEditReassignBtn" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 min-h-[48px] font-medium">
          Hủy
        </button>
        <button id="confirmEditReassignBtn" class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold min-h-[48px]">
          Xác nhận
        </button>
      </div>
    </div>
  </div>

  <script src="/js/admin-dashboard.js"></script>
  <script src="/js/account-switcher.js"></script>
</body>
</html>
