<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <title>Admin Dashboard - ProManage</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body class="bg-gray-100">
  <nav class="bg-white shadow-sm sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8">
      <!-- Header Structure: 2 rows -->
      <div class="py-3">
        <!-- Row 1: Logo -->
        <div class="flex justify-center sm:justify-start mb-3">
          <h1 class="text-xl sm:text-2xl font-bold text-purple-600">ProManage</h1>
        </div>
        
        <!-- Row 2: User Info & Actions (3 columns) -->
        <div class="flex justify-between items-center">
          <!-- Column 1: User Name -->
          <div class="flex-1">
            <p id="userName" class="text-gray-900 font-semibold text-sm sm:text-base"></p>
          </div>
          
          <!-- Column 2: Position + Badge (stacked) -->
          <div class="flex-1 flex flex-col items-center gap-1">
            <p id="userPosition" class="text-xs sm:text-sm text-gray-600 uppercase"></p>
            <span class="px-2 py-1 bg-purple-100 text-purple-800 rounded-full text-xs font-semibold">Admin</span>
          </div>
          
          <!-- Column 3: Action Buttons -->
          <div class="flex-1 flex items-center justify-end gap-2">
            <a href="/user-guide" target="_blank" class="bg-indigo-500 hover:bg-indigo-600 text-white p-2 rounded flex items-center justify-center min-w-[44px] min-h-[44px]" title="Hướng dẫn sử dụng">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </a>
            
            <button id="logoutBtn" class="bg-red-500 hover:bg-red-600 text-white p-2 rounded min-w-[44px] min-h-[44px] flex items-center justify-center" title="Đăng xuất">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <div id="loading" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 text-center">
    <div class="inline-block animate-spin rounded-full h-12 w-12 border-b-2 border-purple-600"></div>
    <p class="mt-4 text-gray-600">Đang tải dữ liệu...</p>
  </div>

  <div id="dashboard" class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-4 sm:py-8 hidden">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 sm:mb-6 gap-3">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Dashboard Admin</h2>
      <div class="grid grid-cols-2 gap-2 sm:gap-3 w-full sm:w-auto">
        <button id="createBroadcastBtn" class="bg-purple-600 hover:bg-purple-700 text-white py-3 rounded-lg font-semibold flex items-center justify-center shadow-lg min-h-[48px]">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Tạo việc
        </button>
        <button id="assignBroadcastBtn" class="bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold flex items-center justify-center shadow-lg min-h-[48px]">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          Giao việc
        </button>
      </div>
    </div>
    
    <!-- Statistics Cards - Main KPIs -->
    <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-4 sm:mb-8">
      <div class="bg-white p-3 sm:p-6 rounded-lg shadow cursor-pointer hover:shadow-lg transition-shadow" data-status="completed">
        <h3 class="text-gray-500 text-xs sm:text-sm font-medium">✅ Đã hoàn thành</h3>
        <p id="completedTasks" class="text-2xl sm:text-3xl font-bold text-green-600 mt-1 sm:mt-2">0</p>
        <p class="text-xs text-gray-400 mt-1">Click để xem chi tiết</p>
      </div>
      <div class="bg-white p-3 sm:p-6 rounded-lg shadow cursor-pointer hover:shadow-lg transition-shadow" data-status="overdue">
        <h3 class="text-gray-500 text-xs sm:text-sm font-medium">⚠️ Quá hạn</h3>
        <p id="overdueTasks" class="text-2xl sm:text-3xl font-bold text-red-600 mt-1 sm:mt-2">0</p>
        <p class="text-xs text-gray-400 mt-1">Click để xem chi tiết</p>
      </div>
      <div class="bg-white p-3 sm:p-6 rounded-lg shadow cursor-pointer hover:shadow-lg transition-shadow" data-status="in-progress">
        <h3 class="text-gray-500 text-xs sm:text-sm font-medium">🔄 Đang làm</h3>
        <p id="inProgressTasks" class="text-2xl sm:text-3xl font-bold text-blue-600 mt-1 sm:mt-2">0</p>
        <p class="text-xs text-gray-400 mt-1">Click để xem chi tiết</p>
      </div>
      <div class="bg-white p-3 sm:p-6 rounded-lg shadow cursor-pointer hover:shadow-lg transition-shadow" data-status="pending-confirm">
        <h3 class="text-gray-500 text-xs sm:text-sm font-medium">⏳ Chưa xác nhận</h3>
        <p id="pendingConfirmTasks" class="text-2xl sm:text-3xl font-bold text-orange-600 mt-1 sm:mt-2">0</p>
        <p class="text-xs text-gray-400 mt-1">Click để xem chi tiết</p>
      </div>
    </div>

    <!-- Task List Section -->
    <div class="bg-white rounded-lg shadow-lg p-4 sm:p-6">
      <div class="mb-4">
        <h3 id="taskListTitle" class="text-lg sm:text-xl font-bold text-gray-900">✅ Đã hoàn thành</h3>
        <p class="text-sm text-gray-500 mt-1">Click vào KPI cards bên trên để xem các loại công việc khác</p>
      </div>
      <div id="taskListContainer" class="space-y-3">
        <p class="text-center text-gray-500 py-8">Đang tải...</p>
      </div>
    </div>
  </div>

  <!-- All Broadcasts Modal -->
  <div id="allBroadcastsModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl max-w-6xl w-full max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex justify-between items-center">
        <h3 class="text-2xl font-bold text-gray-900">Tất cả Công việc</h3>
        <button id="closeAllBroadcastsModal" class="text-gray-400 hover:text-gray-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div class="p-6">
        <!-- Filter tabs -->
        <div class="flex gap-2 mb-4">
          <button class="broadcast-filter-btn active px-4 py-2 rounded-lg" data-status="all">Tất cả</button>
          <button class="broadcast-filter-btn px-4 py-2 rounded-lg" data-status="draft">Nháp</button>
          <button class="broadcast-filter-btn px-4 py-2 rounded-lg" data-status="active">Đang chạy</button>
          <button class="broadcast-filter-btn px-4 py-2 rounded-lg" data-status="completed">Hoàn thành</button>
        </div>
        
        <!-- Broadcasts list -->
        <div id="allBroadcastsList" class="space-y-3">
          <p class="text-gray-500 text-center py-8">Đang tải...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Create Broadcast Modal -->
  <div id="createBroadcastModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-end sm:items-center justify-center p-0 sm:p-4">
    <div class="bg-white rounded-t-2xl sm:rounded-xl shadow-2xl w-full sm:max-w-3xl max-h-[95vh] sm:max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center">
        <h3 class="text-xl sm:text-2xl font-bold text-gray-900">Tạo Công việc mới</h3>
        <button id="closeBroadcastModal" class="text-gray-400 hover:text-gray-600 min-w-[44px] min-h-[44px] flex items-center justify-center">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <form id="broadcastForm" class="p-4 sm:p-6 space-y-4 sm:space-y-6">
        <!-- Title -->
        <div>
          <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Tiêu đề <span class="text-red-500">*</span></label>
          <input type="text" id="broadcastTitle" required class="w-full px-3 sm:px-4 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent text-base min-h-[48px]" placeholder="VD: Kiểm tra hệ thống POS tháng 3/2026">
        </div>

        <!-- Description -->
        <div>
          <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Mô tả <span class="text-red-500">*</span></label>
          <textarea id="broadcastDescription" required rows="4" class="w-full px-3 sm:px-4 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent text-base" placeholder="Mô tả chi tiết công việc cần thực hiện..."></textarea>
        </div>

        <!-- Priority -->
        <div>
          <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Mức độ ưu tiên <span class="text-red-500">*</span></label>
          <select id="broadcastPriority" required class="w-full px-3 sm:px-4 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent text-base min-h-[48px]">
            <option value="low">Thấp</option>
            <option value="medium" selected>Trung bình</option>
            <option value="high">Cao</option>
            <option value="urgent">Khẩn cấp</option>
          </select>
        </div>

        <!-- Checklist Items -->
        <div>
          <label class="block text-gray-700 font-semibold mb-2 text-sm sm:text-base">Checklist <span class="text-red-500">*</span></label>
          <div id="checklistContainer" class="space-y-2 mb-2">
            <div class="flex gap-2">
              <input type="text" class="checklist-item flex-1 px-3 sm:px-4 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent text-base min-h-[48px]" placeholder="1. Kiểm tra máy in bill" required>
              <button type="button" class="remove-checklist-btn hidden bg-red-500 hover:bg-red-600 text-white px-3 rounded-lg min-w-[48px] min-h-[48px]">
                <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
              </button>
            </div>
          </div>
          <button type="button" id="addChecklistBtn" class="text-purple-600 hover:text-purple-700 font-semibold flex items-center min-h-[44px] text-sm sm:text-base">
            <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Thêm checklist item
          </button>
        </div>

        <!-- Deadline Section - UNIFIED (One-time + Recurring) -->
        <div class="border-t border-gray-200 pt-4 space-y-4">
          <div class="border-b pb-2">
            <h3 class="text-lg font-semibold text-gray-800">
              ⏰ Thời hạn hoàn thành <span class="text-red-500">*</span>
            </h3>
          </div>

          <!-- Task Type Selector -->
          <div>
            <label for="taskType" class="block text-sm font-semibold text-gray-700 mb-2">
              Loại công việc
            </label>
            <select id="taskType" required 
                    class="w-full px-3 sm:px-4 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
              <option value="onetime" selected>Làm một lần</option>
              <option value="daily">Lặp hàng ngày</option>
              <option value="weekly">Lặp hàng tuần</option>
              <option value="monthly">Lặp hàng tháng</option>
              <option value="yearly">Lặp hàng năm</option>
            </select>
          </div>

          <!-- ONE-TIME SETTINGS -->
          <div id="onetimeSettings" class="bg-blue-50 p-3 sm:p-4 rounded-lg border border-blue-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Ngày</label>
                <input type="date" id="onetimeDate" required
                       class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
              </div>
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Giờ</label>
                <input type="time" id="onetimeTime" value="14:00" required
                       class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
              </div>
            </div>
            <div class="mt-3 bg-white p-2 rounded border border-blue-300">
              <p class="text-xs text-gray-600">🔮 Deadline:</p>
              <p id="onetimePreview" class="text-sm font-medium text-purple-700"></p>
            </div>
          </div>

          <!-- DAILY SETTINGS -->
          <div id="dailySettings" class="bg-green-50 p-3 sm:p-4 rounded-lg border border-green-200 hidden">
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-3">
              <span class="text-gray-700 text-sm sm:text-base">Mỗi ngày lúc:</span>
              <input type="time" id="dailyTime" value="09:00"
                     class="w-full sm:w-auto px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
            </div>
            <p class="text-xs text-gray-600 italic mt-2">
              💡 Ví dụ: Thực hiện 5S lúc 9:00 sáng mỗi ngày
            </p>
          </div>

          <!-- WEEKLY SETTINGS -->
          <div id="weeklySettings" class="bg-green-50 p-3 sm:p-4 rounded-lg border border-green-200 hidden">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Ngày trong tuần</label>
                <select id="weeklyDay" class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
                  <option value="1">Thứ 2</option>
                  <option value="2">Thứ 3</option>
                  <option value="3">Thứ 4</option>
                  <option value="4">Thứ 5</option>
                  <option value="5">Thứ 6</option>
                  <option value="6" selected>Thứ 7</option>
                  <option value="0">Chủ nhật</option>
                </select>
              </div>
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Giờ</label>
                <input type="time" id="weeklyTime" value="17:00"
                       class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
              </div>
            </div>
            <p class="text-xs text-gray-600 italic mt-2">
              💡 Ví dụ: Kiểm kho vào thứ 7 lúc 17:00 hàng tuần
            </p>
          </div>

          <!-- MONTHLY SETTINGS -->
          <div id="monthlySettings" class="bg-green-50 p-3 sm:p-4 rounded-lg border border-green-200 hidden">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Ngày trong tháng</label>
                <select id="monthlyDay" class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
                  <option value="1">Ngày 1</option>
                  <option value="2" selected>Ngày 2</option>
                  <option value="3">Ngày 3</option>
                  <option value="5">Ngày 5</option>
                  <option value="10">Ngày 10</option>
                  <option value="15">Ngày 15</option>
                  <option value="20">Ngày 20</option>
                  <option value="25">Ngày 25</option>
                  <option value="28">Ngày 28</option>
                  <option value="last">Ngày cuối tháng</option>
                </select>
              </div>
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Giờ</label>
                <input type="time" id="monthlyTime" value="10:00"
                       class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
              </div>
            </div>
            <p class="text-xs text-gray-600 italic mt-2">
              💡 Ví dụ: Chốt bảng chấm công vào ngày 2 lúc 10:00 hàng tháng
            </p>
          </div>

          <!-- YEARLY SETTINGS -->
          <div id="yearlySettings" class="bg-green-50 p-3 sm:p-4 rounded-lg border border-green-200 hidden">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Tháng</label>
                <select id="yearlyMonth" class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
                  <option value="1" selected>Tháng 1</option>
                  <option value="2">Tháng 2</option>
                  <option value="3">Tháng 3</option>
                  <option value="4">Tháng 4</option>
                  <option value="5">Tháng 5</option>
                  <option value="6">Tháng 6</option>
                  <option value="7">Tháng 7</option>
                  <option value="8">Tháng 8</option>
                  <option value="9">Tháng 9</option>
                  <option value="10">Tháng 10</option>
                  <option value="11">Tháng 11</option>
                  <option value="12">Tháng 12</option>
                </select>
              </div>
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Ngày</label>
                <select id="yearlyDay" class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
                  <option value="1">Ngày 1</option>
                  <option value="5">Ngày 5</option>
                  <option value="10">Ngày 10</option>
                  <option value="15" selected>Ngày 15</option>
                  <option value="20">Ngày 20</option>
                  <option value="25">Ngày 25</option>
                  <option value="28">Ngày 28</option>
                  <option value="last">Ngày cuối tháng</option>
                </select>
              </div>
              <div>
                <label class="block text-xs sm:text-sm text-gray-600 mb-1">Giờ</label>
                <input type="time" id="yearlyTime" value="17:00"
                       class="w-full px-3 py-3 sm:py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 text-base min-h-[48px]">
              </div>
            </div>
            <p class="text-xs text-gray-600 italic mt-2">
              💡 Ví dụ: Đánh giá năm vào ngày 15/01 lúc 17:00 hàng năm
            </p>
          </div>

          <!-- Unified Preview -->
          <div class="bg-purple-50 p-3 rounded-lg border border-purple-200">
            <p class="text-xs font-semibold text-gray-600 mb-1">
              🔮 Deadline tiếp theo:
            </p>
            <p id="deadlinePreview" class="text-sm font-medium text-purple-700">
              <!-- Updated by JavaScript -->
            </p>
          </div>
        </div>

        <!-- Alert -->
        <div id="broadcastAlert" class="hidden p-4 rounded-lg"></div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row justify-end gap-3 pt-4 border-t border-gray-200">
          <button type="button" id="cancelBroadcastBtn" class="w-full sm:w-auto px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 min-h-[48px] font-medium">
            Hủy
          </button>
          <button type="submit" id="saveDraftBtn" class="w-full sm:w-auto px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg font-semibold min-h-[48px]">
            💾 Lưu Công việc
          </button>
        </div>
        <p class="text-xs sm:text-sm text-gray-500 mt-3 text-center">
